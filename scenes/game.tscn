[sub_resource type="CanvasItemMaterial" id="CanvasItemMaterial_dinhu"]
blend_mode = 1

[sub_resource type="GDScript" id="GDScript_qouja"]
script/source = "extends Area2D

@export var camera: Camera2D
@export var fragile_ground: Node2D
@export var shake_intensity: float = 5.0
@export var time_before_collapse: float = 1.5

var has_triggered: bool = false

func _on_body_entered(body):
	if body.name == \"Player\" and not has_triggered:
		has_triggered = true
		start_trap_sequence(body)

func start_trap_sequence(player: Node2D):
	if \"is_frozen\" in player:
		player.is_frozen = true
		
	if is_instance_valid(camera) and camera.has_method(\"start_shake\"):
		camera.start_shake(shake_intensity)
	
	await get_tree().create_timer(time_before_collapse).timeout
	
	if is_instance_valid(camera) and camera.has_method(\"stop_shake\"):
		camera.stop_shake()
		
	if \"is_frozen\" in player:
		player.is_frozen = false
		
	if is_instance_valid(fragile_ground):
		fragile_ground.queue_free()
"

